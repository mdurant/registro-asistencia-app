{
  "expo": {
    "name": "Mi Asistencia",
    "slug": "mi-asistencia-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "miasistenciaapp",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "La cámara captura evidencia fotográfica al registrar ingreso y salida en supermercados.",
        "NSLocationWhenInUseUsageDescription": "La ubicación valida que estás en el supermercado asignado al registrar asistencia.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "La ubicación valida tu presencia en el punto de trabajo.",
        "NSFaceIDUsageDescription": "Face ID permite ingresar de forma rápida y segura a la aplicación."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#14B8A6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.miasistenciaapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#14B8A6",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite capturar evidencia al registrar asistencia."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permite validar tu ubicación en el supermercado."
        }
      ],
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
